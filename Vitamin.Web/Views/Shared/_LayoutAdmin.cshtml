    <!--//app-header-->
    <div class="app-wrapper">
        @RenderBody()
        <!--//app-content-->
        <footer class="app-footer">
            <div class="container text-center py-3">

            </div>
        </footer>
        <!--//app-footer-->
    </div><!--//app-wrapper-->
    <!-- Javascript -->
    <script src="~/js/vitamin-bundle.min.js"></script>
</body>
</html>

