                    </div>
                    <!--//row-->
                </div>
                <!--//app-header-content-->
            </div>
            <!--//container-fluid-->
        </div>
        <!--//app-header-inner-->
        <div id="app-sidepanel" class="app-sidepanel sidepanel-visible">
            <div id="sidepanel-drop" class="sidepanel-drop"></div>
            <div class="sidepanel-inner d-flex flex-column">
                @*侧边栏关闭*@
                <a href="/admin" id="sidepanel-close" class="sidepanel-close d-xl-none"></a>
                <div class="app-branding">
                    <a class="app-logo" href="/admin">
                        <img class="logo-icon mr-2" src="~/img/app-logos.svg" alt="logo">
                        <span class="logo-text">Vitamin</span>
                    </a>
                </div>
                <!--//app-branding-->
                <nav id="app-nav-main" class="app-nav app-nav-main flex-grow-1">
